{
  "name": "undercover-game-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/ --fix --cache",
    "format": "prettier --write src/",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:query": "tsx src/db/query.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.1.3",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.42.0",
    "drizzle-zod": "^0.7.1",
    "fastify": "^5.3.2",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.22.5",
    "pino": "^9.7.0",
    "postgres": "^3.4.5",
    "socket.io": "^4.8.3",
    "xstate": "^5.19.3",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.3",
    "drizzle-kit": "^0.30.6",
    "eslint": "^9.26.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
