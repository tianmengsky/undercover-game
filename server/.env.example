# 端口
PORT=3456

# 运行环境
NODE_ENV=development

# JWT 密钥（本地开发用，上线必须换随机值）
JWT_SECRET=dev-secret-at-least-16-chars
JWT_REFRESH_SECRET=dev-refresh-secret-16-chars

# Token 过期时间
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# CORS 来源
CORS_ORIGIN=http://localhost:4173

# Dify AI 接口
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=app-xxxxxxxxxxxxx

# MySQL 数据库
DB_HOST=localhost
DB_PORT=3306
DB_USER=undercover
DB_PASSWORD=Undercover123!
DB_NAME=undercover_game

# Redis（暂未使用）
REDIS_URL=placeholder
